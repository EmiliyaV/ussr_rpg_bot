# Telegram
TELEGRAM_BOT_TOKEN=put_your_telegram_bot_token_here

# Ollama
OLLAMA_ENABLED=true
OLLAMA_MODEL=llama3.2:3b
OLLAMA_GENERATE_URL=http://localhost:11434/api/generate

# Storage
DB_PATH=storage/games.db

# Debug commands
# false by default. Set true only for local testing.
DEBUG_COMMANDS_ENABLED=false
